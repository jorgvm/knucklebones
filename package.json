{
  "name": "@knucklebones/root",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:server": "pnpm --filter @knucklebones/server dev",
    "dev:web": "pnpm --filter @knucklebones/web dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "^2.5.2"
  },
  "packageManager": "pnpm@10.5.2"
}
