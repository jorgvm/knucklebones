{
  "name": "@knucklebones/root",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:server": "turbo run dev --filter=@knucklebones/server",
    "dev:web": "turbo run dev --filter=@knucklebones/web",
    "check": "pnpm typecheck && pnpm test && pnpm lint",
    "type-check": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "^2.5.2"
  },
  "packageManager": "pnpm@10.5.2"
}
